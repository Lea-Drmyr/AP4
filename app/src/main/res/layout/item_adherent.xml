<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    android:background="#1E3A8A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne Nom + Rôle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/itemTxtName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NOM Prénom"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemTxtRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="#3B82F6"
                android:text="ROLE"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#60A5FA" />

        <!-- Email -->
        <TextView
            android:id="@+id/itemTxtEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="8dp"
            android:text="email@exemple.com"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <!-- Téléphone -->
        <TextView
            android:id="@+id/itemTxtPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawableStart="@android:drawable/stat_sys_phone_call"
            android:drawablePadding="8dp"
            android:text="06 00 00 00 00"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <!-- Boutons Modifier / Supprimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="14dp">

            <Button
                android:id="@+id/btnModifier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modifier"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="6dp" />

            <Button
                android:id="@+id/btnSupprimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supprimer"
                android:backgroundTint="#DC2626"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="18dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>